#!/usr/bin/env bash
# Пример адаптера модели для run-skill-evals.py.
#
# Контракт адаптера (переносимый, не привязан к Claude):
#   - вызов: <адаптер> <модель>;
#   - промпт читается со стандартного ввода;
#   - текст ответа модели пишется в стандартный вывод;
#   - код выхода 0 — успех, любой другой — транспортная ошибка вызова модели.
#
# Средство запуска само вкладывает требование вернуть JSON в текст промпта и
# разбирает JSON из ответа. Адаптеру достаточно вернуть текст модели как есть.
#
# Это пример для Claude Code CLI. Под другую модель напишите свой адаптер по
# тому же контракту и укажите его в локальных настройках evals.
#
# Изоляция запуска. Claude автоматически подхватывает CLAUDE.md из текущего
# каталога, поэтому адаптер запускает модель из пустого временного каталога,
# чтобы правила целевого проекта не протекали в прогон навыка. Вход остаётся
# через обычный доступ Claude Code, включая подписку OAuth; пользовательские
# настройки, перехватчики и память уровня дома при этом сохраняются.
set -euo pipefail

if [[ $# -lt 1 || -z "${1:-}" ]]; then
  echo "Использование: claude <модель>; промпт на stdin, ответ на stdout." >&2
  exit 2
fi

model="$1"
prompt="$(cat)"

workdir="$(mktemp -d)"
trap 'rm -rf "$workdir"' EXIT

# В headless-режиме --print с текстовым выводом финальный ответ модели идёт
# прямо в stdout, поэтому отдельный файл для ответа не нужен. --strict-mcp-config
# без --mcp-config отключает все серверы MCP, чтобы прогон не зависел от
# окружения пользователя.
printf '%s' "$prompt" | (
  cd "$workdir" && claude \
    --print \
    --strict-mcp-config \
    --output-format text \
    --model "$model"
)
