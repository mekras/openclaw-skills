# Локальная конфигурация модельных evals (apm run evals).
#
# Это образец. При первом запуске тестов он будет скопирован в evals.local.yml.

# Адаптеры моделей: имя адаптера -> команда. Контракт адаптера:
# <команда> <модель>; запрос на stdin, текст ответа на stdout.
adapters:
#  codex: tools/adapters/codex
#  claude: tools/adapters/claude

# Модели для применения навыков в формате адаптер:модель. Каждая запись
# прогоняется отдельно, результаты сопоставимы по одинаковым критериям.
# Здесь держите слабые модели: прогон должен проверять навык на слабом звене.
models:
  - codex:gpt-5.3-codex-spark
#  - claude:sonnet

# Модель-судья в формате адаптер:модель.
# Задавать обязательно. Назначайте сильную модель.
judge: codex:gpt-5.5

# Тайм-аут одного вызова адаптера в секундах.
timeout: 900
